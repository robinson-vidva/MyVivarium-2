# Route every /api/v1/* request through index.php.
# index.php parses REQUEST_URI itself to figure out the API path.

RewriteEngine On
RewriteBase /api/

# Disable content-negotiation fallbacks. MultiViews can cause Apache to
# resolve /api/v1/mice to ../index.php (the login page) when no rewrite
# matches, which historically caused the chatbot to receive HTML instead
# of JSON.
Options -MultiViews

# Allow direct hits to index.php to pass through unchanged.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^index\.php$ - [L]

# Send everything else (v1/whatever) to the router.
RewriteRule ^ index.php [QSA,L]

# Default response type.
DirectoryIndex index.php

# Forward Authorization-style headers in CGI/FCGI setups that strip them.
<IfModule mod_setenvif.c>
    SetEnvIfNoCase ^Authorization$ "(.+)" HTTP_AUTHORIZATION=$1
</IfModule>

# Belt-and-braces: if for any reason a parent ErrorDocument tries to
# redirect to the project root, force the API to respond with JSON 404.
ErrorDocument 404 "{\"ok\":false,\"error\":{\"code\":\"not_found\",\"message\":\"API route not found\"}}"
